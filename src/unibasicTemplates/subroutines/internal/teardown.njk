subroutine mvom_teardown(teardownOptions)
* Perform any needed environment teardown
{% include "../../common/mvom.njk" %}

if S$MVOM.COMO.LOGGING ne 'off' then
  * no-op if como logging was not turned on earlier
  execute 'COMO OFF ':S$MVOM.COMO.LOG.ID
end

clearcommon /S$MVOM/

returnFromSub:
return; * returning to caller
